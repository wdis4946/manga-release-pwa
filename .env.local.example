RAKUTEN_APPLICATION_ID=
RAKUTEN_ACCESS_KEY=
RAKUTEN_AFFILIATE_ID=
APP_ORIGIN=https://manga-release-pwa.vercel.app

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Direct PostgreSQL connection string used only by the one-time rebuild route.
SUPABASE_DB_URL=

# Set to true only immediately before the one-time database rebuild, then remove.
ALLOW_DATABASE_REBUILD=false

# Protects server-side batch endpoints. Use a long random value.
CRON_SECRET=

# Comma-separated Supabase Auth email addresses allowed into the admin UI.
ADMIN_EMAILS=

# OpenAI Batch API for series summary generation.
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-4.1
OPENAI_WEB_SEARCH_TOOL_TYPE=web_search_preview

# Source collection for series summaries.
# crawler: fetch publisher/official pages directly without search API cost.
# google: legacy Google Custom Search JSON API.
SOURCE_SEARCH_PROVIDER=crawler
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
